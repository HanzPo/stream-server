# URL of the webpage to stream
WEBPAGE_URL=https://example.com

# RTMP stream URL (including stream key)
# YouTube: rtmp://a.rtmp.youtube.com/live2/YOUR_STREAM_KEY
# Twitch: rtmp://live.twitch.tv/app/YOUR_STREAM_KEY
STREAM_URL=rtmp://a.rtmp.youtube.com/live2/YOUR_STREAM_KEY

# Stream settings (optional)
RESOLUTION=1920x1080
FRAMERATE=30
VIDEO_BITRATE=4500k
AUDIO_BITRATE=128k
